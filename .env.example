# Development Database Configuration
DB_HOST=db
DB_PORT=5432
POSTGRES_USER=vyapar_local
POSTGRES_PASSWORD=change-this-local-development-password
POSTGRES_DB=vyapar_pulse

# Backend API Configuration
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3005
COOKIE_SECURE=false
DEMO_ACCESS_ENABLED=true

# Auth Configuration
JWT_SECRET=replace_this_with_a_secure_random_string_for_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Demo Seeding Password
DEMO_USER_PASSWORD=prototype-only-password

# LLM Configuration (Set these for production)
OPENAI_API_KEY=
VYAPAR_VERSION=1.3.4
